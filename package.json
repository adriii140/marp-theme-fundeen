{
  "name": "@fundeen/marp-theme",
  "version": "0.1.2",
  "description": "Fundeen Marp theme for presentations",
  "main": "fundeen.css",
  "files": [
    "fundeen.css"
  ],
  "keywords": [
    "marp",
    "marp-theme",
    "fundeen",
    "presentation",
    "slides"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/adriii140/marp-theme-fundeen.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "marp example.md",
    "preview": "marp --preview example.md",
    "serve": "marp --server .",
    "embed-assets": "node scripts/embed-assets.js",
    "release": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4"
  }
}
